{
  "info": {
    "_postman_id": "6f4f5178-1e3f-4e12-a13d-518f4e9d17a2",
    "name": "Hospital Orientation API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "API success login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@hospital.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const responseJson = pm.response.json();",
              "pm.test(\"Response contains success message\", function () {",
              "  pm.expect(responseJson.message).to.eql(\"Login successful\");",
              "});",
              "",
              "pm.sendRequest({",
              "  url: pm.collectionVariables.get('baseUrl') + '/api/test-result',",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/json' },",
              "  body: {",
              "    mode: 'raw',",
              "    raw: JSON.stringify({",
              "      test_case_id: 4,",
              "      actual_output: responseJson.message,",
              "      status: responseJson.message === 'Login successful' ? 'Pass' : 'Fail'",
              "    })",
              "  }",
              "}, function (err, res) {",
              "  if (err) {",
              "    console.log('Failed to push result:', err);",
              "  } else {",
              "    console.log('Stored API success result:', res.code);",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "API failure login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"fake@hospital.com\",\n  \"password\": \"wrongpass\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 401\", function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "",
              "const responseJson = pm.response.json();",
              "pm.test(\"Response contains invalid credentials message\", function () {",
              "  pm.expect(responseJson.message).to.eql(\"Invalid credentials\");",
              "});",
              "",
              "pm.sendRequest({",
              "  url: pm.collectionVariables.get('baseUrl') + '/api/test-result',",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/json' },",
              "  body: {",
              "    mode: 'raw',",
              "    raw: JSON.stringify({",
              "      test_case_id: 5,",
              "      actual_output: responseJson.message,",
              "      status: responseJson.message === 'Invalid credentials' ? 'Pass' : 'Fail'",
              "    })",
              "  }",
              "}, function (err, res) {",
              "  if (err) {",
              "    console.log('Failed to push result:', err);",
              "  } else {",
              "    console.log('Stored API failure result:', res.code);",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ]
}
